{# Shared form utilities for auth pages #}

{% macro auth_form(title, subtitle, subtitle_link, submit_text, submit_loading_text) %}
<div class="min-h-[calc(100vh-4rem)] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-900">{{ title }}</h1>
            <p class="mt-2 text-gray-600">{{ subtitle }} <a href="{{ subtitle_link.href }}" class="text-indigo-600 hover:text-indigo-700 font-medium">{{ subtitle_link.text }}</a></p>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
            <div class="space-y-4">
                {{ caller() }}
                <p id="msg" class="text-red-500 text-sm hidden"></p>
                <button type="submit" id="btnSubmit"
                    class="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-2.5 rounded-lg font-medium transition-colors flex items-center justify-center">
                    <span id="btnText">{{ submit_text }}</span>
                    <span id="btnSpinner" class="hidden ml-2">
                        {% include "components/spinner.jinja" %}
                    </span>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    const button = document.getElementById("btnSubmit");
    const btnText = document.getElementById("btnText");
    const btnSpinner = document.getElementById("btnSpinner");
    const msgEl = document.getElementById("msg");

    function showError(message) {
        msgEl.textContent = message;
        msgEl.classList.remove("hidden");
    }

    function setLoading(loading) {
        button.disabled = loading;
        btnText.textContent = loading ? "{{ submit_loading_text }}" : "{{ submit_text }}";
        if (loading) {
            btnSpinner.classList.remove("hidden");
        } else {
            btnSpinner.classList.add("hidden");
        }
    }
</script>
{% endmacro %}

{% macro input(id, label, type, placeholder="") %}
<div>
    <label for="{{ id }}" class="block text-sm font-medium text-gray-700 mb-1">{{ label }}</label>
    <input type="{{ type }}" id="{{ id }}" {% if placeholder %}placeholder="{{ placeholder }}"{% endif %} required
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all">
</div>
{% endmacro %}