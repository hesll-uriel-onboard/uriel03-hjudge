<!-- Submission History Modal Component -->
<div id="submissionModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg max-w-lg w-full mx-4 max-h-[80vh] overflow-hidden">
        <div class="p-6 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Submission History</h3>
            <button onclick="closeSubmissionModal()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <div id="modalContent" class="p-6 overflow-y-auto max-h-[60vh]">
            <!-- Submission history will be loaded here -->
        </div>
    </div>
</div>

<script>
// Store submissions data for each exercise
const exerciseSubmissions = {};

function showSubmissionHistory(exerciseId) {
    const submissions = exerciseSubmissions[exerciseId] || [];
    const modal = document.getElementById('submissionModal');
    const content = document.getElementById('modalContent');

    if (submissions.length === 0) {
        content.innerHTML = '<p class="text-gray-500 dark:text-gray-400 text-center">No submissions yet</p>';
    } else {
        const verdictColors = {
            'AC': 'bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300',
            'WA': 'bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300',
            'TLE': 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300',
            'RTE': 'bg-orange-100 text-orange-700 dark:bg-orange-900 dark:text-orange-300'
        };

        content.innerHTML = `
            <table class="w-full">
                <thead class="bg-gray-50 dark:bg-gray-700">
                    <tr>
                        <th class="px-4 py-2 text-left text-sm font-semibold text-gray-700 dark:text-gray-200">ID</th>
                        <th class="px-4 py-2 text-left text-sm font-semibold text-gray-700 dark:text-gray-200">Date</th>
                        <th class="px-4 py-2 text-center text-sm font-semibold text-gray-700 dark:text-gray-200">Verdict</th>
                        <th class="px-4 py-2 text-center text-sm font-semibold text-gray-700 dark:text-gray-200">Points</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                    ${submissions.map(s => `
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                            <td class="px-4 py-3 text-sm">
                                <a href="${s.url}" target="_blank" class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-mono">
                                    ${s.submission_id}
                                </a>
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
                                ${new Date(s.submitted_at).toLocaleDateString()}
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium ${verdictColors[s.verdict] || 'bg-gray-100 text-gray-700 dark:bg-gray-600 dark:text-gray-200'}">
                                    ${s.verdict}
                                </span>
                            </td>
                            <td class="px-4 py-3 text-center text-sm font-bold ${s.points > 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400'}">
                                ${s.points || 0}
                            </td>
                        </tr>
                    `).join('')}
                </tbody>
            </table>
        `;
    }

    modal.classList.remove('hidden');
    modal.classList.add('flex');
}

function closeSubmissionModal() {
    const modal = document.getElementById('submissionModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
}

// Close modal on outside click
document.getElementById('submissionModal').addEventListener('click', function(e) {
    if (e.target === this) {
        closeSubmissionModal();
    }
});

// Close modal on Escape key
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        closeSubmissionModal();
    }
});
</script>