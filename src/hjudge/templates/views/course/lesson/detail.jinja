{% extends "base.jinja" %}

{% block content %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-6">
        <a href="/courses/{{ course.slug }}" class="text-indigo-600 hover:text-indigo-700">{{ course.title }}</a>
        <span class="mx-2 text-gray-400">/</span>
        <span class="text-gray-600">Lesson {{ lesson.order }}: {{ lesson.title }}</span>
    </nav>

    <!-- Lesson Content -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
        <div class="flex justify-between items-start">
            <h1 class="text-3xl font-bold text-gray-900 mb-6">{{ lesson.title }}</h1>
            {% if is_admin %}
            <a href="/courses/{{ course.slug }}/lessons/{{ lesson.slug }}/edit" class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                Edit Lesson
            </a>
            {% endif %}
        </div>
        <div class="prose max-w-none text-gray-700">
            {{ lesson.content }}
        </div>
    </div>

    <!-- Exercises -->
    <div id="exercisesSection" class="mt-8 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hidden">
        <div class="p-6 border-b border-gray-200">
            <h2 class="text-xl font-semibold text-gray-900">Exercises</h2>
        </div>
        <table class="w-full">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Judge</th>
                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Code</th>
                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">Title</th>
                    <th class="px-6 py-4 text-center text-sm font-semibold text-gray-700">Result</th>
                </tr>
            </thead>
            <tbody id="exercisesList" class="divide-y divide-gray-200">
                <!-- Exercises will be loaded here -->
            </tbody>
        </table>
    </div>

<!-- Submission History Modal Component -->
{% include "components/submission_modal.jinja" %}

<!-- Navigation -->
<div class="mt-8 flex justify-between">
        {% if prev_lesson %}
        <a href="/courses/{{ course.slug }}/lessons/{{ prev_lesson.slug }}" class="text-indigo-600 hover:text-indigo-700">
            ← Previous: {{ prev_lesson.title }}
        </a>
        {% else %}
        <div></div>
        {% endif %}

        {% if next_lesson %}
        <a href="/courses/{{ course.slug }}/lessons/{{ next_lesson.slug }}" class="text-indigo-600 hover:text-indigo-700">
            Next: {{ next_lesson.title }} →
        </a>
        {% endif %}
    </div>
</div>

<script>
    const exerciseIds = [
        {% for id in lesson.exercise_ids %}
            "{{ id }}",
        {% endfor %}
    ];

    async function loadExercises() {
        if (!exerciseIds || exerciseIds.length === 0) return;

        const section = document.getElementById("exercisesSection");
        const list = document.getElementById("exercisesList");

        for (const exerciseId of exerciseIds) {
            try {
                const response = await fetch(`/api/exercises/${exerciseId}`);
                if (response.ok) {
                    const exercise = await response.json();

                    const tr = document.createElement("tr");
                    tr.className = "hover:bg-gray-50 transition-colors";
                    tr.dataset.exerciseId = exercise.id;
                    tr.innerHTML = `
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
                                ${exercise.judge === 'CODEFORCES' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-700'}
                            ">
                                ${exercise.judge}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-gray-600 font-mono">${exercise.code}</td>
                        <td class="px-6 py-4">
                            <a href="${exercise.url}" target="_blank"
                                class="text-indigo-600 hover:text-indigo-700 font-medium hover:underline">
                                ${exercise.title || exercise.code}
                            </a>
                        </td>
                        <td class="px-6 py-4 text-center">
                            {% if (user is defined) and not(user == none) %}
                            <span class="result-display inline-flex items-center justify-center w-12 h-8 rounded-lg text-sm font-bold cursor-pointer"
                                data-exercise-id="${exercise.id}">
                                -
                            </span>
                            {% else %}
                            <span class="text-gray-400">-</span>
                            {% endif %}
                        </td>
                    `;
                    list.appendChild(tr);
                }
            } catch (error) {
                console.error(`Failed to load exercise ${exerciseId}`, error);
            }
        }

        if (list.children.length > 0) {
            section.classList.remove("hidden");
            {% if (user is defined) and not(user == none) %}
            loadSubmissionResults();
            {% endif %}
        }
    }

    {% if (user is defined) and not(user == none) %}
    const USER_ID = "{{ user.id }}";

    async function loadSubmissionResults() {
        const resultDisplays = document.querySelectorAll('.result-display');
        const exerciseIds = Array.from(resultDisplays).map(el => el.dataset.exerciseId);

        const promises = exerciseIds.map(async exerciseId => {
            try {
                const response = await fetch(`/api/submissions?user=${USER_ID}&exercise=${exerciseId}`);
                if (response.ok) {
                    const submissions = await response.json();
                    return { exerciseId, submissions };
                }
            } catch (error) {
                console.error(`Failed to load submissions for exercise ${exerciseId}:`, error);
            }
            return { exerciseId, submissions: [] };
        });

        const results = await Promise.all(promises);

        results.forEach(({ exerciseId, submissions }) => {
            const display = document.querySelector(`.result-display[data-exercise-id="${exerciseId}"]`);
            if (!display) return;

            // Store submissions for modal
            exerciseSubmissions[exerciseId] = submissions;

            if (submissions.length === 0) {
                display.textContent = "0";
                display.className = "result-display inline-flex items-center justify-center w-12 h-8 rounded-lg text-sm font-bold cursor-pointer bg-red-100 text-red-700";
            } else {
                // Calculate max points
                const maxPoints = Math.max(...submissions.map(s => s.points || 0));
                const hasAC = submissions.some(s => s.verdict === "AC");

                display.textContent = maxPoints;

                // Color coding
                if (hasAC) {
                    display.className = "result-display inline-flex items-center justify-center w-12 h-8 rounded-lg text-sm font-bold cursor-pointer bg-green-100 text-green-700 hover:bg-green-200";
                } else if (maxPoints > 0) {
                    display.className = "result-display inline-flex items-center justify-center w-12 h-8 rounded-lg text-sm font-bold cursor-pointer bg-yellow-100 text-yellow-700 hover:bg-yellow-200";
                } else {
                    display.className = "result-display inline-flex items-center justify-center w-12 h-8 rounded-lg text-sm font-bold cursor-pointer bg-red-100 text-red-700 hover:bg-red-200";
                }

                // Add click handler for modal
                display.addEventListener('click', () => showSubmissionHistory(exerciseId));
            }
        });
    }
    {% endif %}

    loadExercises();
</script>
{% endblock %}