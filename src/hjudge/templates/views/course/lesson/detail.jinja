{% extends "base.jinja" %}

{% block content %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-6">
        <a href="/courses/{{ course.slug }}" class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300">{{ course.title }}</a>
        <span class="mx-2 text-gray-400">/</span>
        <span class="text-gray-600 dark:text-gray-300">Lesson {{ lesson.order }}: {{ lesson.title }}</span>
    </nav>

    <!-- Lesson Content -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8 mb-8">
        <div class="flex justify-between items-start mb-4">
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">{{ lesson.title }}</h1>
            {% if is_admin %}
            <a href="/courses/{{ course.slug }}/lessons/{{ lesson.slug }}/edit" class="bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                Edit Lesson
            </a>
            {% endif %}
        </div>
        <div class="prose max-w-none text-gray-700 dark:text-gray-300 mb-4">
            {{ lesson.content }}
        </div>
        {% if (user is defined) and not(user == none) %}
        <div id="lesson-progress" class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
            <div class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Your Progress</div>
            <div id="lesson-progress-bar">
                <div class="flex items-center justify-center">
                    <div class="animate-spin rounded-full h-5 w-5 border-b-2 border-indigo-600"></div>
                </div>
            </div>
        </div>
        {% endif %}
    </div>

    <!-- Exercises -->
    <div id="exercisesSection" class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden hidden">
        <div class="p-6 border-b border-gray-200 dark:border-gray-700">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Exercises</h2>
        </div>
        <table class="w-full">
            <thead class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
                <tr>
                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700 dark:text-gray-200">Judge</th>
                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700 dark:text-gray-200">Code</th>
                    <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700 dark:text-gray-200">Title</th>
                    <th class="px-6 py-4 text-center text-sm font-semibold text-gray-700 dark:text-gray-200">Result</th>
                </tr>
            </thead>
            <tbody id="exercisesList" class="divide-y divide-gray-200 dark:divide-gray-700">
                <!-- Exercises will be loaded here -->
            </tbody>
        </table>
    </div>

    <!-- Dashboard -->
    {% include "components/dashboard.jinja" %}

<!-- Submission History Modal Component -->
{% include "components/submission_modal.jinja" %}

<!-- Navigation -->
<div class="mt-8 flex justify-between">
        {% if prev_lesson %}
        <a href="/courses/{{ course.slug }}/lessons/{{ prev_lesson.slug }}" class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300">
            ← Previous: {{ prev_lesson.title }}
        </a>
        {% else %}
        <div></div>
        {% endif %}

        {% if next_lesson %}
        <a href="/courses/{{ course.slug }}/lessons/{{ next_lesson.slug }}" class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300">
            Next: {{ next_lesson.title }} →
        </a>
        {% endif %}
    </div>
</div>

<script>
    const lessonId = '{{ lesson.id }}';
    const exerciseIds = [
        {% for id in lesson.exercise_ids %}
            "{{ id }}",
        {% endfor %}
    ];

    // Store exercise info for leaderboard labels
    const exerciseInfo = {};

    async function loadExercises() {
        if (!exerciseIds || exerciseIds.length === 0) return;

        const section = document.getElementById("exercisesSection");
        const list = document.getElementById("exercisesList");

        for (const exerciseId of exerciseIds) {
            try {
                const response = await fetch(`/api/exercises/${exerciseId}`);
                if (response.ok) {
                    const exercise = await response.json();

                    // Store for leaderboard labels
                    const judgeShort = exercise.judge === 'CODEFORCES' ? 'CF' : exercise.judge.slice(0, 2);
                    exerciseInfo[exercise.id] = `${judgeShort}_${exercise.code}`;

                    const tr = document.createElement("tr");
                    tr.className = "hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors";
                    tr.dataset.exerciseId = exercise.id;
                    tr.innerHTML = `
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
                                ${exercise.judge === 'CODEFORCES' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' : 'bg-gray-100 text-gray-700 dark:bg-gray-600 dark:text-gray-200'}
                            ">
                                ${exercise.judge}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-gray-600 dark:text-gray-300 font-mono">${exercise.code}</td>
                        <td class="px-6 py-4">
                            <a href="${exercise.url}" target="_blank"
                                class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-medium hover:underline">
                                ${exercise.title || exercise.code}
                            </a>
                        </td>
                        <td class="px-6 py-4 text-center">
                            {% if (user is defined) and not(user == none) %}
                            <span class="result-display inline-flex items-center justify-center w-12 h-8 rounded-lg text-sm font-bold cursor-pointer"
                                data-exercise-id="${exercise.id}">
                                -
                            </span>
                            {% else %}
                            <span class="text-gray-400 dark:text-gray-500">-</span>
                            {% endif %}
                        </td>
                    `;
                    list.appendChild(tr);
                }
            } catch (error) {
                console.error(`Failed to load exercise ${exerciseId}`, error);
            }
        }

        if (list.children.length > 0) {
            section.classList.remove("hidden");
            {% if (user is defined) and not(user == none) %}
            loadSubmissionResults();
            {% endif %}
        }
    }

    {% if (user is defined) and not(user == none) %}
    const USER_ID = "{{ user.id }}";

    async function loadSubmissionResults() {
        // Use batch API instead of N+1 queries
        try {
            const response = await fetch(`/api/submissions/batch?user=${USER_ID}&exercises=${exerciseIds.join(',')}`);
            if (response.ok) {
                const maxPoints = await response.json();

                document.querySelectorAll('.result-display').forEach(display => {
                    const exerciseId = display.dataset.exerciseId;
                    const points = maxPoints[exerciseId] || 0;

                    display.textContent = points;

                    if (points === 0) {
                        display.className = "result-display inline-flex items-center justify-center w-12 h-8 rounded-lg text-sm font-bold cursor-pointer bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300";
                    } else if (points === 100) {
                        display.className = "result-display inline-flex items-center justify-center w-12 h-8 rounded-lg text-sm font-bold cursor-pointer bg-green-100 text-green-700 hover:bg-green-200 dark:bg-green-900 dark:text-green-300 dark:hover:bg-green-800";
                    } else {
                        display.className = "result-display inline-flex items-center justify-center w-12 h-8 rounded-lg text-sm font-bold cursor-pointer bg-yellow-100 text-yellow-700 hover:bg-yellow-200 dark:bg-yellow-900 dark:text-yellow-300 dark:hover:bg-yellow-800";
                    }

                    // Load submissions for modal on click
                    display.addEventListener('click', async () => {
                        if (!exerciseSubmissions[exerciseId]) {
                            const resp = await fetch(`/api/submissions?user=${USER_ID}&exercise=${exerciseId}`);
                            if (resp.ok) {
                                exerciseSubmissions[exerciseId] = await resp.json();
                            }
                        }
                        showSubmissionHistory(exerciseId);
                    });
                });
            }
        } catch (error) {
            console.error('Failed to load submission results:', error);
        }
    }

    // Load lesson progress
    fetch(`/api/dashboard/lesson/${lessonId}`)
        .then(resp => resp.json())
        .then(data => {
            renderProgressBar('lesson-progress-bar', data.total_points);
        })
        .catch(e => {
            document.getElementById('lesson-progress-bar').innerHTML = '';
        });
    {% endif %}

    // Load dashboard after exercises are loaded (to get exercise info for labels)
    loadExercises().then(() => {
        const breakdownLabels = exerciseIds.map(id => exerciseInfo[id] || id.slice(0, 8));
        loadDashboard(
            `/api/dashboard/lesson/${lessonId}/leaderboard`,
            breakdownLabels
        );
    });
</script>
{% endblock %}