{% extends "base.jinja" %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Exercises</h1>
        <p class="text-gray-600 dark:text-gray-300 mt-1">Browse and solve programming problems</p>
    </div>

    {% if exercises %}
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
                    <tr>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700 dark:text-gray-200">Judge</th>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700 dark:text-gray-200">Code</th>
                        <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700 dark:text-gray-200">Title</th>
                        <th class="px-6 py-4 text-center text-sm font-semibold text-gray-700 dark:text-gray-200">Result</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                    {% for exercise in exercises %}
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors" data-exercise-id="{{ exercise['content'].id }}">
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
                                {% if exercise['content'].judge.value == 'CODEFORCES' %}
                                bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300
                                {% else %}
                                bg-gray-100 text-gray-700 dark:bg-gray-600 dark:text-gray-200
                                {% endif %}
                            ">
                                {{ exercise["content"].judge.value }}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-gray-600 dark:text-gray-300 font-mono">{{ exercise["content"].code }}</td>
                        <td class="px-6 py-4">
                            <a href="{{ exercise['url'] }}" target="_blank"
                                class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-medium hover:underline">
                                {{ exercise["content"].title }}
                            </a>
                        </td>
                        <td class="px-6 py-4 text-center">
                            {% if (user is defined) and not(user == none) %}
                            {% set exercise_id = exercise['content'].id | string %}
                            {% set prog = progress.get(exercise_id, {}) %}
                            {% set max_points = prog.get('max_points', 0) %}
                            {% set has_ac = prog.get('has_ac', false) %}
                            <span class="result-display inline-flex items-center justify-center w-12 h-8 rounded-lg text-sm font-bold cursor-pointer"
                                data-exercise-id="{{ exercise['content'].id }}"
                                {% if max_points > 0 or has_ac %}
                                data-points="{{ max_points }}"
                                data-has-ac="{{ 'true' if has_ac else 'false' }}"
                                {% endif %}
                                onclick="loadAndShowHistory('{{ exercise['content'].id }}', '{{ user.id }}')">
                                {% if max_points > 0 or has_ac %}
                                {{ max_points }}
                                {% else %}
                                0
                                {% endif %}
                            </span>
                            {% else %}
                            <span class="text-gray-400 dark:text-gray-500">-</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# Pagination controls #}
    {% if total_pages > 1 %}
    <div class="mt-6 flex items-center justify-between">
        <p class="text-sm text-gray-600 dark:text-gray-400">
            Showing page {{ page }} of {{ total_pages }} ({{ total }} total exercises)
        </p>
        <div class="flex gap-2">
            {% if page > 1 %}
            <a href="?page={{ page - 1 }}" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600">
                Previous
            </a>
            {% else %}
            <span class="px-4 py-2 text-sm font-medium text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg cursor-not-allowed">
                Previous
            </span>
            {% endif %}

            {% if page < total_pages %}
            <a href="?page={{ page + 1 }}" class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700">
                Next
            </a>
            {% else %}
            <span class="px-4 py-2 text-sm font-medium text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg cursor-not-allowed">
                Next
            </span>
            {% endif %}
        </div>
    </div>
    {% endif %}
    {% else %}
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <h3 class="mt-4 text-lg font-medium text-gray-900 dark:text-white">No exercises found</h3>
        <p class="mt-2 text-gray-500 dark:text-gray-400">Check back later for new problems to solve.</p>
    </div>
    {% endif %}
</div>

<!-- Submission History Modal Component -->
{% include "components/submission_modal.jinja" %}

{% if (user is defined) and not(user == none) %}
<script>
    const USER_ID = "{{ user.id }}";

    // Initialize result displays with proper styling
    function initResultDisplays() {
        const resultDisplays = document.querySelectorAll('.result-display');
        resultDisplays.forEach(display => {
            const hasAc = display.dataset.hasAc === 'true';
            const points = parseInt(display.dataset.points || '0');

            if (hasAc) {
                display.className = "result-display inline-flex items-center justify-center w-12 h-8 rounded-lg text-sm font-bold cursor-pointer bg-green-100 text-green-700 hover:bg-green-200 dark:bg-green-900 dark:text-green-300 dark:hover:bg-green-800";
            } else if (points > 0) {
                display.className = "result-display inline-flex items-center justify-center w-12 h-8 rounded-lg text-sm font-bold cursor-pointer bg-yellow-100 text-yellow-700 hover:bg-yellow-200 dark:bg-yellow-900 dark:text-yellow-300 dark:hover:bg-yellow-800";
            } else {
                display.className = "result-display inline-flex items-center justify-center w-12 h-8 rounded-lg text-sm font-bold cursor-pointer bg-red-100 text-red-700 hover:bg-red-200 dark:bg-red-900 dark:text-red-300 dark:hover:bg-red-800";
            }
        });
    }

    // Load and show submission history on click
    async function loadAndShowHistory(exerciseId, userId) {
        try {
            const response = await fetch(`/api/submissions?user=${userId}&exercise=${exerciseId}`);
            if (response.ok) {
                const submissions = await response.json();
                showSubmissionHistory(exerciseId, submissions);
            }
        } catch (error) {
            console.error('Failed to load submission history:', error);
        }
    }

    initResultDisplays();
</script>
{% endif %}
{% endblock %}