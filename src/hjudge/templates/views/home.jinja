{% extends "base.jinja" %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Welcome to HJudge</h1>
        <p class="text-xl text-gray-600 mb-8">Your platform for competitive programming practice</p>

        {% if (user is defined) and not(user == none) %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 max-w-md mx-auto">
            <p class="text-gray-600 mb-6">Ready to solve some problems?</p>
            <a href="/exercises" class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-lg font-medium transition-colors">
                Browse Exercises
            </a>
        </div>
        {% else %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 max-w-md mx-auto">
            <p class="text-gray-600 mb-6">Join us to start solving problems and tracking your progress!</p>
            <div class="flex justify-center space-x-4">
                <a href="/login" class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-6 py-3 rounded-lg font-medium transition-colors">
                    Login
                </a>
                <a href="/register" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-lg font-medium transition-colors">
                    Get Started
                </a>
            </div>
        </div>
        {% endif %}
    </div>

    <div class="mt-16 grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <div class="text-indigo-600 text-2xl font-bold mb-2">100+</div>
            <div class="text-gray-600">Problems available</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <div class="text-indigo-600 text-2xl font-bold mb-2">Codeforces</div>
            <div class="text-gray-600">Integrated judges</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <div class="text-indigo-600 text-2xl font-bold mb-2">Track</div>
            <div class="text-gray-600">Your submissions</div>
        </div>
    </div>
</div>
{% endblock %}