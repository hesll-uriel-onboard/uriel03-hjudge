{% extends "base.jinja" %}
{% from "components/form_macros.jinja" import auth_form, input %}

{% block content %}
{% call auth_form("Create your account", "Already have an account?", {"href": "/login", "text": "Sign in"}, "Create account", "Creating account...") %}
    {{ input("txtName", "Full Name", "text") }}
    {{ input("txtUsername", "Username", "text") }}
    {{ input("txtPassword", "Password", "password", "Create a password") }}
{% endcall %}

<script>
    button.addEventListener("click", async function() {
        const name = document.getElementById("txtName").value.trim();
        const username = document.getElementById("txtUsername").value.trim();
        const password = document.getElementById("txtPassword").value;

        if (!name || !username || !password) {
            showError("Please fill in all fields");
            return;
        }

        setLoading(true);

        try {
            const response = await fetch("/api/register", {
                method: "POST",
                body: JSON.stringify({ username, password, name }),
                headers: { "Content-Type": "application/json; charset=UTF-8" }
            });

            const data = await response.json();

            if (response.ok) {
                window.location.href = "/login";
            } else {
                showError(data.detail || "Registration failed");
            }
        } catch (error) {
            showError("An error occurred. Please try again.");
        } finally {
            setLoading(false);
        }
    });
</script>
{% endblock %}